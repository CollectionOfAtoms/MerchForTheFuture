# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is in .gitignore.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/art_auction"
DATABASE_URL_TEST="postgresql://user:password@localhost:5432/art_auction_test"

# ── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# ── OAuth providers ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CONNECT_CLIENT_ID=""

# ── Tax API (TaxJar or Avalara) ───────────────────────────────────────────────
TAXJAR_API_KEY=""
# AVALARA_ACCOUNT_ID=""
# AVALARA_LICENSE_KEY=""

# ── Print fulfillment (Prodigi) ───────────────────────────────────────────────
# Use a sandbox key (starts with "test_") from dashboard.prodigi.com for local dev.
# Production key goes in Vercel env vars only — never commit it.
PRODIGI_API_KEY=""
# Defaults to the live API when unset. Set to sandbox for local dev and staging.
# Sandbox: https://api.sandbox.prodigi.com/v4.0
# Live:    https://api.prodigi.com/v4.0  (leave unset in production)
PRODIGI_API_BASE_URL="https://api.sandbox.prodigi.com/v4.0"

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="noreply@yourdomain.com"

# ── Image hosting (Vercel Blob) ───────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=""

# ── App ───────────────────────────────────────────────────────────────────────
# Base URL used in transactional emails (password reset links, order confirmations, etc.)
# Set to https://localhost:3000 for local dev so reset links open your local server.
# Production: set to https://artandsol.quest in Vercel environment variables.
NEXT_PUBLIC_BASE_URL="https://localhost:3000"
PLATFORM_FEE_PERCENT="10"
