generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  BUYER
  SELLER
  ADMIN
}

enum ArtworkStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SaleType {
  FIXED_PRICE
  AUCTION
}

enum ListingStatus {
  ACTIVE
  /// Visible only by direct link to the detail page; hidden from every browse/
  /// feed and excluded from "active" counts. A seller's pre-launch draft state —
  /// they can build and preview a listing without it going live. Distinct from
  /// ARCHIVED (retired/hidden, not viewable).
  UNLISTED
  SOLD
  RESERVE_NOT_MET
  CANCELLED
  ARCHIVED
}

enum AuctionStatus {
  SCHEDULED
  ACTIVE
  CLOSED
  CANCELLED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum OrderListingType {
  ORIGINAL
  PRINT
  /// Multi-item cart checkout (US-MFTF-12.4). Such orders carry OrderItem +
  /// FulfillmentOrder rows and leave the single-listing FKs null.
  CART
}

/// Status of one per-provider shipment within a multi-item cart order (US-MFTF-12.2).
/// Per-provider shipment status within a multi-item cart order (US-MFTF-12.2),
/// aligned with the canonical `FulfillmentStatus` set from US-MFTF-3.1 so provider
/// progression can be persisted (US-MFTF-14.2). PENDING/SUBMITTED are the placement
/// lifecycle before the provider accepts the order; CONFIRMED is the canonical
/// PROCESSING base; PRINTING/SHIPPED/DELIVERED are the forward progression; FAILED
/// is the canonical ERROR. Forward order is monotonic (see src/lib/fulfillment/status.ts);
/// CANCELLED and FAILED are always-allowed terminal states.
enum FulfillmentOrderStatus {
  PENDING
  SUBMITTED
  CONFIRMED
  PRINTING
  SHIPPED
  DELIVERED
  CANCELLED
  FAILED
}

/// Polymorphic line-item kind for the shopping cart (US-MFTF-11.1). APPAREL items
/// reference an `ApparelListing`; PRINT items reference the artwork `OriginalListing`
/// they are printed from. Each kind has its own `selection` validator
/// (`src/lib/cart/validators.ts`).
enum CartItemKind {
  APPAREL
  PRINT
}

enum NotificationType {
  OUTBID
  AUCTION_WON
  AUCTION_LOST
  AUCTION_CLOSED
  ORDER_SHIPPED
  ORDER_DELIVERED
  RESERVE_NOT_MET
}

// ─── User & Auth ──────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  emailVerified    DateTime?
  name             String?
  image            String?
  passwordHash     String?
  roles            Role[]    @default([BUYER])
  twoFactorEnabled Boolean   @default(false)
  stripeAccountId  String?
  loginMetadata    Json?
  taxExemption     Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  artworks        Artwork[]
  bids            Bid[]
  orders          Order[]
  notifications   Notification[]
  addresses       UserAddress[]
  apparelListings ApparelListing[]
  cart            Cart?

  @@index([email])
}

model UserAddress {
  id        String   @id @default(cuid())
  userId    String
  name      String
  line1     String
  line2     String?
  city      String
  state     String?
  postal    String
  country   String   @default("US")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  token     String   @unique
  email     String
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model EmailVerificationToken {
  token     String   @unique
  email     String
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── Artwork ──────────────────────────────────────────────────────────────────

model Artwork {
  id          String        @id @default(cuid())
  sellerId    String
  title       String
  artist      String?
  description String        @db.Text
  medium      String?
  dimensions  String?
  year        Int?
  metadata    Json?
  status      ArtworkStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  seller          User             @relation(fields: [sellerId], references: [id])
  images          ArtworkImage[]
  originalListing OriginalListing?

  @@index([sellerId])
  @@index([status])
}

model ArtworkImage {
  id           String   @id @default(cuid())
  artworkId    String
  url          String
  displayUrl   String?
  gridUrl      String?
  thumbnailUrl String?
  isPrimary    Boolean  @default(false)
  order        Int      @default(0)
  createdAt    DateTime @default(now())

  artwork Artwork @relation(fields: [artworkId], references: [id], onDelete: Cascade)

  @@index([artworkId])
}

// ─── Listings ─────────────────────────────────────────────────────────────────

model OriginalListing {
  id                  String        @id @default(cuid())
  artworkId           String        @unique
  saleType            SaleType
  price               Decimal?      @db.Decimal(12, 2)
  currency            String        @default("USD")
  status              ListingStatus @default(ACTIVE)
  availableForPrint   Boolean       @default(false)
  printSourceImageUrl String?
  printProducts       Json?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  artwork Artwork  @relation(fields: [artworkId], references: [id], onDelete: Cascade)
  auction Auction?
  orders  Order[]
  cartItems CartItem[]
  orderItems OrderItem[]

  @@index([status])
  @@index([availableForPrint])
}

model Auction {
  id                String        @id @default(cuid())
  originalListingId String        @unique
  startBid          Decimal       @db.Decimal(12, 2)
  reservePrice      Decimal?      @db.Decimal(12, 2)
  currentBid        Decimal?      @db.Decimal(12, 2)
  currentBidderId   String?
  bidCount          Int           @default(0)
  endAt             DateTime
  status            AuctionStatus @default(SCHEDULED)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  originalListing OriginalListing @relation(fields: [originalListingId], references: [id], onDelete: Cascade)
  bids            Bid[]

  @@index([status])
  @@index([endAt])
}

model Bid {
  id        String   @id @default(cuid())
  auctionId String
  bidderId  String
  amount    Decimal  @db.Decimal(12, 2)
  placedAt  DateTime @default(now())

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  bidder  User    @relation(fields: [bidderId], references: [id])

  @@index([auctionId])
  @@index([bidderId])
}

// ─── Orders & Transactions ────────────────────────────────────────────────────

model Order {
  id                    String           @id @default(cuid())
  buyerId               String
  listingType           OrderListingType
  originalListingId     String?
  /// FK to ApparelListing — set for apparel orders; null for original/print orders
  apparelListingId      String?
  /// Provider-agnostic SKU sent to the fulfillment provider (e.g. Prodigi print SKU or Teemill variant ref)
  externalSku           String?
  printSize             String?
  quantity              Int              @default(1)
  subtotal              Decimal          @db.Decimal(12, 2)
  taxAmount             Decimal          @db.Decimal(12, 2) @default(0)
  taxRate               Decimal?         @db.Decimal(6, 4)
  taxJurisdiction       String?
  totalAmount           Decimal          @db.Decimal(12, 2)
  currency              String           @default("USD")
  shippingName          String?
  shippingLine1         String?
  shippingLine2         String?
  shippingCity          String?
  shippingState         String?
  shippingPostal        String?
  shippingCountry       String?
  stripePaymentIntentId String?          @unique
  stripeSessionId       String?          @unique
  /// Provider-agnostic external order ID returned by the fulfillment provider after submission
  externalOrderId       String?
  trackingNumber        String?
  carrier               String?
  paymentDeadline       DateTime?
  status                OrderStatus      @default(PENDING)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  buyer           User              @relation(fields: [buyerId], references: [id])
  originalListing OriginalListing?  @relation(fields: [originalListingId], references: [id])
  apparelListing  ApparelListing?   @relation(fields: [apparelListingId], references: [id])
  transaction     Transaction?
  /// Cart-checkout line items (US-MFTF-12.2). Empty for legacy single-FK orders.
  orderItems        OrderItem[]
  /// Per-provider shipment groups (US-MFTF-12.2). Empty for legacy single-FK orders.
  fulfillmentOrders FulfillmentOrder[]

  @@index([buyerId])
  @@index([status])
}

/// A line item on a multi-item cart Order (US-MFTF-12.2). Polymorphic over
/// `CartItemKind` exactly like `CartItem`: APPAREL → `apparelListingId`, PRINT →
/// `listingId`. App-layer invariant (`src/lib/orders/invariants.ts`): exactly one
/// FK is non-null. `unitPrice` is the authoritative price captured at checkout.
model OrderItem {
  id                 String       @id @default(cuid())
  orderId            String
  itemKind           CartItemKind
  apparelListingId   String?
  listingId          String?
  selection          Json
  quantity           Int          @default(1)
  unitPrice          Decimal      @db.Decimal(12, 2)
  fulfillmentOrderId String?
  createdAt          DateTime     @default(now())

  order            Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  apparelListing   ApparelListing?   @relation(fields: [apparelListingId], references: [id])
  originalListing  OriginalListing?  @relation(fields: [listingId], references: [id])
  fulfillmentOrder FulfillmentOrder? @relation(fields: [fulfillmentOrderId], references: [id])

  @@index([orderId])
  @@index([fulfillmentOrderId])
}

/// One per-provider shipment group within a cart Order (US-MFTF-12.2). Holds the
/// resolved provider registry key, the provider's order id, shipment status, the
/// quoted shipping method/cost, and tracking once shipped.
model FulfillmentOrder {
  id              String                 @id @default(cuid())
  orderId         String
  provider        String
  providerOrderId String?
  status          FulfillmentOrderStatus @default(PENDING)
  shippingMethod  String?
  shippingCost    Decimal                @default(0) @db.Decimal(12, 2)
  trackingNumber  String?
  carrier         String?
  /// Unguessable per-shipment secret embedded in the provider's per-order callback
  /// URL (US-MFTF-14.1). The Prodigi webhook authenticates AND resolves the shipment
  /// from this token alone (?token=…), so a leaked token compromises one order only
  /// and each environment self-addresses its own callbacks. Generated at fan-out.
  webhookToken    String?                @unique
  notes           String?                @db.Text
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  order Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items OrderItem[]

  @@index([orderId])
  @@index([status])
}

model Transaction {
  id                 String   @id @default(cuid())
  orderId            String   @unique
  stripeChargeId     String?
  grossAmount        Decimal  @db.Decimal(12, 2)
  platformFee        Decimal  @db.Decimal(12, 2)
  processingFee      Decimal  @db.Decimal(12, 2)
  netPayout          Decimal  @db.Decimal(12, 2)
  /// Cost charged by the fulfillment provider (provider-agnostic; was prodigiFulfillmentCost)
  fulfillmentCost    Decimal? @db.Decimal(12, 2)
  currency           String   @default("USD")
  createdAt          DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])
}

// ─── Product Catalog ──────────────────────────────────────────────────────────

enum FulfillmentProviderType {
  TEEMILL
  PRODIGI
}

model ProductType {
  id                  String                 @id @default(cuid())
  name                String                 @unique
  description         String?
  fulfillmentProvider FulfillmentProviderType
  providerSkuBase     String
  isActive            Boolean                @default(true)
  /// Admin-uploaded product blank photo (used for Prodigi products; Teemill products use API-sourced images)
  blankImageUrl       String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  colors          ProductTypeColor[]
  sizes           ProductTypeSizeOption[]
  apparelListings ApparelListing[]

  @@index([isActive])
}

model ProductTypeColor {
  id                String      @id @default(cuid())
  productTypeId     String
  /// Human-readable color name (e.g. "Navy Blue") — also used as the display label in seller UIs
  colorName         String
  /// String sent to the fulfillment provider's API to identify this color.
  /// May be the same as colorName (Teemill) or a different code (other providers).
  providerColorCode String
  /// Provider-sourced color photo URL (populated from Teemill catalog; may be null for Prodigi)
  colorImageUrl     String?

  productType       ProductType          @relation(fields: [productTypeId], references: [id], onDelete: Cascade)
  apparelListingColors ApparelListingColor[]

  @@index([productTypeId])
}

model ProductTypeSizeOption {
  id               String      @id @default(cuid())
  productTypeId    String
  sizeLabel        String
  providerSizeCode String
  sortOrder        Int

  productType ProductType @relation(fields: [productTypeId], references: [id], onDelete: Cascade)

  @@index([productTypeId])
}

// ─── Apparel Listings (MFTF-5 / MFTF-13) ──────────────────────────────────────

/// How an apparel listing is sourced.
/// DESIGNED   — seller uploads a clean design file onto a founder-curated blank
///              (Prodigi today); platform owns colour/size curation (MFTF-4/5).
/// REFERENCED — founder builds the product on the provider's site (Teemill today)
///              and references it; the provider owns blank/design/colours/sizes/
///              stock/price, cached as a ReferencedVariant snapshot (MFTF-13).
enum SourcingMode {
  DESIGNED
  REFERENCED
}

model ApparelListing {
  id             String        @id @default(cuid())
  sellerId       String
  sourcingMode   SourcingMode  @default(DESIGNED)
  /// DESIGNED listings only — null for REFERENCED.
  productTypeId  String?
  title          String
  description    String?       @db.Text
  retailPrice    Decimal       @db.Decimal(12, 2)
  status         ListingStatus @default(ACTIVE)
  /// Clean design file URL (no watermark) — sent directly to the fulfillment
  /// provider. DESIGNED listings only; null for REFERENCED (provider owns the design).
  designImageUrl String?
  /// REFERENCED listings only — fulfillment registry key (e.g. "teemill").
  providerKey         String?
  /// REFERENCED listings only — the provider product ref/id the snapshot is keyed off.
  providerProductRef  String?
  /// REFERENCED listings only — the provider product slug (captured at ingest),
  /// used to build the "Edit on Teemill" per-product editor deep-link.
  providerProductSlug String?
  /// REFERENCED listings only — ISO 4217 currency of providerBasePrice (e.g. "GBP").
  providerBaseCurrency String?
  /// REFERENCED listings only — cached provider base cost for margin monitoring;
  /// NEVER used to compute the buyer's USD retail price.
  providerBasePrice   Decimal?  @db.Decimal(12, 2)
  /// REFERENCED listings only — when the cached snapshot was last refreshed.
  snapshotFetchedAt   DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  seller            User                  @relation(fields: [sellerId], references: [id])
  productType       ProductType?          @relation(fields: [productTypeId], references: [id])
  colors            ApparelListingColor[]
  images            ApparelListingImage[]
  referencedVariants ReferencedVariant[]
  orders            Order[]
  cartItems         CartItem[]
  orderItems        OrderItem[]

  @@index([sellerId])
  @@index([status])
  @@index([productTypeId])
  @@index([providerProductRef])
}

/// Cached, orderable variant snapshot for a REFERENCED (Teemill) apparel listing.
/// One row per orderable colour × size combination, ingested from the provider
/// catalog (US-MFTF-13.2). Buyers/checkout read these; only the FulfillmentProvider
/// subclass turns `variantRef` back into a provider order.
model ReferencedVariant {
  id               String  @id @default(cuid())
  apparelListingId String
  /// Absolute orderable variant URL, e.g. https://api.teemill.com/v1/catalog/variants/{uuid}
  variantRef       String
  colorName        String
  /// Hex from the variant `Colour` attribute `{type:"color", value}`.
  colorHex         String
  sizeLabel        String
  /// Stock level cached at snapshot time.
  stockLevel       Int
  isOrderable      Boolean @default(true)
  /// Per-colour mockup URL from `variant.images[]`/`product.images[]` (by variantIds).
  mockupUrl        String?

  apparelListing ApparelListing @relation(fields: [apparelListingId], references: [id], onDelete: Cascade)

  @@index([apparelListingId])
}

model ApparelListingColor {
  id                  String  @id @default(cuid())
  apparelListingId    String
  productTypeColorId  String
  /// Whether the seller is offering this color on their listing
  isOffered           Boolean @default(true)

  apparelListing   ApparelListing   @relation(fields: [apparelListingId], references: [id], onDelete: Cascade)
  productTypeColor ProductTypeColor @relation(fields: [productTypeColorId], references: [id])

  @@unique([apparelListingId, productTypeColorId])
  @@index([apparelListingId])
}

model ApparelListingImage {
  id               String   @id @default(cuid())
  apparelListingId String
  originalUrl      String
  displayUrl       String?
  gridUrl          String?
  thumbnailUrl     String?
  isPrimary        Boolean  @default(false)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())

  apparelListing ApparelListing @relation(fields: [apparelListingId], references: [id], onDelete: Cascade)

  @@index([apparelListingId])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  payload   Json
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

// ─── Cart (MFTF-11) ───────────────────────────────────────────────────────────

/// A shopping cart for a guest or an authenticated buyer (US-MFTF-11.1). Exactly
/// one of `userId` / `guestToken` is non-null — enforced at the application layer
/// (`src/lib/cart/invariants.ts`), consistent with the US-MFTF-5.1 single-FK
/// convention. Guest carts are keyed by an httpOnly-cookie token; on login/signup
/// the guest cart merges into the user cart (US-MFTF-11.5) and is deleted. A daily
/// cron prunes guest carts inactive 30+ days off `updatedAt` (US-MFTF-11.6), so
/// every mutation must touch `updatedAt`.
model Cart {
  id         String   @id @default(cuid())
  userId     String?  @unique
  guestToken String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user  User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]

  @@index([guestToken])
}

/// A polymorphic cart line item (US-MFTF-11.1). `itemKind` selects which listing
/// reference is set: APPAREL → `apparelListingId`; PRINT → `listingId` (the artwork
/// `OriginalListing` the print is made from). Exactly one reference is non-null and
/// must match `itemKind` (app-layer invariant). `selection` is a per-kind JSON
/// payload validated by `src/lib/cart/validators.ts`
/// (APPAREL → { colorId, sizeLabel }; PRINT → { prodigiSku, attributes, quotedUnitPrice }).
model CartItem {
  id               String       @id @default(cuid())
  cartId           String
  itemKind         CartItemKind
  apparelListingId String?
  listingId        String?
  selection        Json
  quantity         Int          @default(1)
  addedAt          DateTime     @default(now())

  cart            Cart             @relation(fields: [cartId], references: [id], onDelete: Cascade)
  apparelListing  ApparelListing?  @relation(fields: [apparelListingId], references: [id])
  originalListing OriginalListing? @relation(fields: [listingId], references: [id])

  @@index([cartId])
}
