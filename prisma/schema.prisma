generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  BUYER
  SELLER
  ADMIN
}

enum ArtworkStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SaleType {
  FIXED_PRICE
  AUCTION
}

enum ListingStatus {
  ACTIVE
  SOLD
  RESERVE_NOT_MET
  CANCELLED
  ARCHIVED
}

enum AuctionStatus {
  SCHEDULED
  ACTIVE
  CLOSED
  CANCELLED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum OrderListingType {
  ORIGINAL
  PRINT
}

enum NotificationType {
  OUTBID
  AUCTION_WON
  AUCTION_LOST
  AUCTION_CLOSED
  ORDER_SHIPPED
  ORDER_DELIVERED
  RESERVE_NOT_MET
}

// ─── User & Auth ──────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  emailVerified    DateTime?
  name             String?
  image            String?
  passwordHash     String?
  roles            Role[]    @default([BUYER])
  twoFactorEnabled Boolean   @default(false)
  stripeAccountId  String?
  loginMetadata    Json?
  taxExemption     Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  artworks      Artwork[]
  bids          Bid[]
  orders        Order[]
  notifications Notification[]
  addresses     UserAddress[]

  @@index([email])
}

model UserAddress {
  id        String   @id @default(cuid())
  userId    String
  name      String
  line1     String
  line2     String?
  city      String
  state     String?
  postal    String
  country   String   @default("US")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  token     String   @unique
  email     String
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model EmailVerificationToken {
  token     String   @unique
  email     String
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── Artwork ──────────────────────────────────────────────────────────────────

model Artwork {
  id          String        @id @default(cuid())
  sellerId    String
  title       String
  artist      String?
  description String        @db.Text
  medium      String?
  dimensions  String?
  year        Int?
  metadata    Json?
  status      ArtworkStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  seller          User             @relation(fields: [sellerId], references: [id])
  images          ArtworkImage[]
  originalListing OriginalListing?

  @@index([sellerId])
  @@index([status])
}

model ArtworkImage {
  id           String   @id @default(cuid())
  artworkId    String
  url          String
  displayUrl   String?
  gridUrl      String?
  thumbnailUrl String?
  isPrimary    Boolean  @default(false)
  order        Int      @default(0)
  createdAt    DateTime @default(now())

  artwork Artwork @relation(fields: [artworkId], references: [id], onDelete: Cascade)

  @@index([artworkId])
}

// ─── Listings ─────────────────────────────────────────────────────────────────

model OriginalListing {
  id                  String        @id @default(cuid())
  artworkId           String        @unique
  saleType            SaleType
  price               Decimal?      @db.Decimal(12, 2)
  currency            String        @default("USD")
  status              ListingStatus @default(ACTIVE)
  availableForPrint   Boolean       @default(false)
  printSourceImageUrl String?
  printProducts       Json?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  artwork Artwork  @relation(fields: [artworkId], references: [id], onDelete: Cascade)
  auction Auction?
  orders  Order[]

  @@index([status])
  @@index([availableForPrint])
}

model Auction {
  id                String        @id @default(cuid())
  originalListingId String        @unique
  startBid          Decimal       @db.Decimal(12, 2)
  reservePrice      Decimal?      @db.Decimal(12, 2)
  currentBid        Decimal?      @db.Decimal(12, 2)
  currentBidderId   String?
  bidCount          Int           @default(0)
  endAt             DateTime
  status            AuctionStatus @default(SCHEDULED)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  originalListing OriginalListing @relation(fields: [originalListingId], references: [id], onDelete: Cascade)
  bids            Bid[]

  @@index([status])
  @@index([endAt])
}

model Bid {
  id        String   @id @default(cuid())
  auctionId String
  bidderId  String
  amount    Decimal  @db.Decimal(12, 2)
  placedAt  DateTime @default(now())

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  bidder  User    @relation(fields: [bidderId], references: [id])

  @@index([auctionId])
  @@index([bidderId])
}

// ─── Orders & Transactions ────────────────────────────────────────────────────

model Order {
  id                    String           @id @default(cuid())
  buyerId               String
  listingType           OrderListingType
  originalListingId     String?
  prodigiSku            String?
  printSize             String?
  quantity              Int              @default(1)
  subtotal              Decimal          @db.Decimal(12, 2)
  taxAmount             Decimal          @db.Decimal(12, 2) @default(0)
  taxRate               Decimal?         @db.Decimal(6, 4)
  taxJurisdiction       String?
  totalAmount           Decimal          @db.Decimal(12, 2)
  currency              String           @default("USD")
  shippingName          String?
  shippingLine1         String?
  shippingLine2         String?
  shippingCity          String?
  shippingState         String?
  shippingPostal        String?
  shippingCountry       String?
  stripePaymentIntentId String?          @unique
  stripeSessionId       String?          @unique
  prodigiOrderId        String?
  trackingNumber        String?
  carrier               String?
  paymentDeadline       DateTime?
  status                OrderStatus      @default(PENDING)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  buyer           User             @relation(fields: [buyerId], references: [id])
  originalListing OriginalListing? @relation(fields: [originalListingId], references: [id])
  transaction     Transaction?

  @@index([buyerId])
  @@index([status])
}

model Transaction {
  id                    String   @id @default(cuid())
  orderId               String   @unique
  stripeChargeId        String?
  grossAmount           Decimal  @db.Decimal(12, 2)
  platformFee           Decimal  @db.Decimal(12, 2)
  processingFee         Decimal  @db.Decimal(12, 2)
  netPayout             Decimal  @db.Decimal(12, 2)
  prodigiFulfillmentCost Decimal? @db.Decimal(12, 2)
  currency              String   @default("USD")
  createdAt             DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])
}

// ─── Product Catalog ──────────────────────────────────────────────────────────

enum FulfillmentProviderType {
  TEEMILL
  PRODIGI
}

model ProductType {
  id                  String                 @id @default(cuid())
  name                String                 @unique
  description         String?
  fulfillmentProvider FulfillmentProviderType
  providerSkuBase     String
  isActive            Boolean                @default(true)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  colors ProductTypeColor[]
  sizes  ProductTypeSizeOption[]

  @@index([isActive])
}

model ProductTypeColor {
  id                String      @id @default(cuid())
  productTypeId     String
  colorName         String
  colorHex          String
  providerColorCode String
  isActive          Boolean     @default(true)

  productType ProductType @relation(fields: [productTypeId], references: [id], onDelete: Cascade)

  @@index([productTypeId])
}

model ProductTypeSizeOption {
  id               String      @id @default(cuid())
  productTypeId    String
  sizeLabel        String
  providerSizeCode String
  sortOrder        Int
  isActive         Boolean     @default(true)

  productType ProductType @relation(fields: [productTypeId], references: [id], onDelete: Cascade)

  @@index([productTypeId])
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  payload   Json
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}
